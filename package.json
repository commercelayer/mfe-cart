{
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "preview": "pnpm -r preview",
    "check": "pnpm lint",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:e2e": "pnpm -r test:e2e",
    "dep:major": "pnpm dlx npm-check-updates --packageFile '**/package.json' -u",
    "dep:semver": "pnpm dlx npm-check-updates --packageFile '**/package.json' -t semver -u",
    "clean": "pnpx rimraf --glob **/node_modules **/pnpm-lock.yaml"
  },
  "keywords": [],
  "author": {
    "name": "Giuseppe Ciotola",
    "email": "giuseppe@commercelayer.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/commercelayer/monorepo-starter.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^19.6.6"
  }
}
